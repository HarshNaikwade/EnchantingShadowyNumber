# Backend
BACKEND_PORT=8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
FRONTEND_ORIGINS=http://localhost:5000

# AI Provider
# Options: lmstudio, ollama, groq
AI_PROVIDER=lmstudio
AI_CONNECTION_CACHE_SECONDS=60

# LM Studio (local)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=google/gemma-4-e4b

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# Groq (cloud)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional future frontend override
# VITE_API_BASE_URL=http://localhost:8000

# Optional future database override
# DATABASE_URL=sqlite:///./apps/backend/compliance_checker.db
