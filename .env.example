# ── Backend ────────────────────────────────────────────────────────
BACKEND_PORT=8000

# SQLite path (default: apps/backend/compliance_checker.db)
# DATABASE_URL=sqlite:///./compliance_checker.db

# Absolute path for uploads (default: <project-root>/uploads)
# UPLOAD_DIR=/absolute/path/to/uploads

MAX_UPLOAD_MB=50

# Comma-separated allowed CORS origins
FRONTEND_ORIGINS=http://localhost:5000

# ── AI Provider ────────────────────────────────────────────────────
# "ollama" for local inference, "groq" for cloud
AI_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq (cloud) — only needed when AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Frontend (Vite) ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
