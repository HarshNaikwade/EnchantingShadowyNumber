# ── Backend ────────────────────────────────────────────────────────
BACKEND_PORT=8000

# SQLite path (default: apps/backend/compliance_checker.db)
# DATABASE_URL=sqlite:///./compliance_checker.db

# Absolute path for uploads (default: <project-root>/uploads)
# UPLOAD_DIR=/absolute/path/to/uploads

MAX_UPLOAD_MB=50

# Comma-separated allowed CORS origins
FRONTEND_ORIGINS=http://localhost:5000

# ── AI Provider ────────────────────────────────────────────────────
# Options: "lmstudio" (local, recommended), "ollama" (local), "groq" (cloud)
AI_PROVIDER=lmstudio

# LMStudio (local, OpenAI-compatible) — Download from https://lmstudio.ai
# Requires: LMStudio running with a model loaded on port 1234
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=google/gemma-4-e4b

# Ollama (local) — Download from https://ollama.ai
# Requires: ollama serve running on port 11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# Groq (cloud) — Get API key from https://console.groq.com
# Only needed when AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Frontend (Vite) ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
