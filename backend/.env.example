# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose between "ollama" (local) or "groq" (cloud).
AI_PROVIDER=ollama

# ── Ollama (used when AI_PROVIDER=ollama) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# ── Groq (used when AI_PROVIDER=groq) ─────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./compliance_checker.db

# ── File uploads ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ── Server ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_ORIGINS=http://localhost:5000
