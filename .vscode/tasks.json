{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: dev server",
      "type": "shell",
      "command": ".venv/Scripts/python.exe",
      "args": [
        "-m",
        "uvicorn",
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--app-dir",
        "apps/backend"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Frontend: dev server",
      "type": "shell",
      "command": "npx",
      "args": [
        "vite",
        "apps/frontend",
        "--host",
        "0.0.0.0",
        "--port",
        "5173"
      ],
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe"
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
